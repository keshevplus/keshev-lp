# All variables must start with VITE_ to be exposed in the client bundle.
# Do NOT put secrets here - copy this to .env.local (gitignored) for local dev.

# keshevplus platform API - this page is standalone and has no backend of its
# own; the contact form posts straight to the shared keshevplus API, and the
# submission shows up in the same admin dashboard/CRM as the main site.
VITE_API_BASE_URL=https://api.keshevplus.com

# Where "admin" links on this page point to. The admin dashboard lives
# entirely on the keshevplus platform, never in this repo.
VITE_ADMIN_DASHBOARD_URL=https://admin.keshevplus.com

VITE_PHONE_DISPLAY=055-27-399-27
VITE_PHONE_TEL=0552739927
